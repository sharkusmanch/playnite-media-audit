<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Menu -->
    <sys:String x:Key="LOC_MediaAudit_MenuSection">Media Audit</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Menu_ScanAll">Alle spelmedia scannen</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Menu_ScanSelected">Media van geselecteerde spellen scannen</sys:String>

    <!-- Notifications -->
    <sys:String x:Key="LOC_MediaAudit_Notification_NoSelection">Media Audit: Geen spellen geselecteerd.</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Notification_NoIssues">Media Audit: Geen problemen gevonden.</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Notification_IssuesFound">Media Audit: {0} problemen gevonden ({1}).</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Notification_IssuesFoundDetail">Media Audit: {0} problemen gevonden ({1}). Controleer de speltags voor details.</sys:String>

    <!-- Settings: Section Headers -->
    <sys:String x:Key="LOC_MediaAudit_Section_General">Algemeen</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_MediaTypes">Te controleren mediatypen</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_IconStandards">Pictogramstandaarden</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_CoverStandards">Coverstandaarden</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_BackgroundStandards">Achtergrondstandaarden</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_Logo">Extra Metadata - Logo</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_Videos">Extra Metadata - Video's</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_GameMusic">PlayniteSound - Spelmuziek</sys:String>

    <!-- Settings: General -->
    <sys:String x:Key="LOC_MediaAudit_Settings_BackgroundScanEnabled">Intervalgebaseerd scannen op de achtergrond inschakelen</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_ScanInterval">Scaninterval (minuten):</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_ReportMissing">Ontbrekende media melden</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_ShowScanNotification">Melding tonen na achtergrondscan</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_TagUndesiredMedia">Spellen met problemen taggen</sys:String>

    <!-- Settings: Media Types -->
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckIcons">Pictogrammen controleren</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckCovers">Covers controleren</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckBackgrounds">Achtergronden controleren</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckLogos">Logo's controleren</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckTrailers">Trailers controleren</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckMicrotrailers">Microtrailers controleren</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckGameMusic">Spelmuziek controleren</sys:String>

    <!-- Settings: Common Labels -->
    <sys:String x:Key="LOC_MediaAudit_Settings_Preset">Voorinstelling:</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_TagName">Tagnaam:</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_MinSize">Min. grootte (px):</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_MaxSize">Max. grootte (px):</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_AspectRatioTolerance">Beeldverhoudingstolerantie:</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_ExpectedAspectRatio">Verwachte beeldverhouding:</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_MinWidth">Min. breedte (px):</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_MinHeight">Min. hoogte (px):</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_InstalledOnly">Alleen ge&#239;nstalleerde spellen</sys:String>

    <!-- Settings: Video-specific Labels -->
    <sys:String x:Key="LOC_MediaAudit_Settings_TrailerInstalledOnly">Trailers: alleen ge&#239;nstalleerde spellen</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_TrailerTagName">Trailer-tagnaam:</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_MicrotrailerInstalledOnly">Microtrailers: alleen ge&#239;nstalleerde spellen</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_MicrotrailerTagName">Microtrailer-tagnaam:</sys:String>

    <!-- Validation Errors -->
    <sys:String x:Key="LOC_MediaAudit_Validation_ScanInterval">Scaninterval moet minimaal 1 minuut zijn.</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Validation_IconMinSize">Minimale pictogramgrootte moet minimaal 1 pixel zijn.</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Validation_CoverMinDimensions">Minimale coverafmetingen moeten minimaal 1 pixel zijn.</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Validation_BackgroundMinDimensions">Minimale achtergrondafmetingen moeten minimaal 1 pixel zijn.</sys:String>
</ResourceDictionary>

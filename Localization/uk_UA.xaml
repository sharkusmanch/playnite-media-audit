<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Menu -->
    <sys:String x:Key="LOC_MediaAudit_MenuSection">Media Audit</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Menu_ScanAll">Сканувати медіа всіх ігор</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Menu_ScanSelected">Сканувати медіа вибраних ігор</sys:String>

    <!-- Notifications -->
    <sys:String x:Key="LOC_MediaAudit_Notification_NoSelection">Media Audit: Ігри не вибрано.</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Notification_NoIssues">Media Audit: Проблем не знайдено.</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Notification_IssuesFound">Media Audit: Знайдено проблем: {0} ({1}).</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Notification_IssuesFoundDetail">Media Audit: Знайдено проблем: {0} ({1}). Перевірте теги ігор для деталей.</sys:String>

    <!-- Settings: Section Headers -->
    <sys:String x:Key="LOC_MediaAudit_Section_General">Загальні</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_MediaTypes">Типи медіа для перевірки</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_IconStandards">Стандарти значків</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_CoverStandards">Стандарти обкладинок</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_BackgroundStandards">Стандарти фонів</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_Logo">Extra Metadata - Логотип</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_Videos">Extra Metadata - Відео</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_GameMusic">PlayniteSound - Ігрова музика</sys:String>

    <!-- Settings: General -->
    <sys:String x:Key="LOC_MediaAudit_Settings_BackgroundScanEnabled">Увімкнути фонове сканування за інтервалом</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_ScanInterval">Інтервал сканування (хвилини):</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_ReportMissing">Повідомляти про відсутні медіа</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_ShowScanNotification">Показувати сповіщення після фонового сканування</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_TagUndesiredMedia">Позначати ігри з проблемами тегами</sys:String>

    <!-- Settings: Media Types -->
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckIcons">Перевіряти значки</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckCovers">Перевіряти обкладинки</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckBackgrounds">Перевіряти фони</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckLogos">Перевіряти логотипи</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckTrailers">Перевіряти трейлери</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckMicrotrailers">Перевіряти мікротрейлери</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckGameMusic">Перевіряти ігрову музику</sys:String>

    <!-- Settings: Common Labels -->
    <sys:String x:Key="LOC_MediaAudit_Settings_Preset">Шаблон:</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_TagName">Назва тегу:</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_MinSize">Мін. розмір (px):</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_MaxSize">Макс. розмір (px):</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_AspectRatioTolerance">Допуск співвідношення сторін:</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_ExpectedAspectRatio">Очікуване співвідношення сторін:</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_MinWidth">Мін. ширина (px):</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_MinHeight">Мін. висота (px):</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_InstalledOnly">Лише встановлені ігри</sys:String>

    <!-- Settings: Video-specific Labels -->
    <sys:String x:Key="LOC_MediaAudit_Settings_TrailerInstalledOnly">Трейлери: лише встановлені ігри</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_TrailerTagName">Назва тегу трейлера:</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_MicrotrailerInstalledOnly">Мікротрейлери: лише встановлені ігри</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_MicrotrailerTagName">Назва тегу мікротрейлера:</sys:String>

    <!-- Validation Errors -->
    <sys:String x:Key="LOC_MediaAudit_Validation_ScanInterval">Інтервал сканування має бути не менше 1 хвилини.</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Validation_IconMinSize">Мінімальний розмір значка має бути не менше 1 пікселя.</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Validation_CoverMinDimensions">Мінімальні розміри обкладинки мають бути не менше 1 пікселя.</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Validation_BackgroundMinDimensions">Мінімальні розміри фону мають бути не менше 1 пікселя.</sys:String>
</ResourceDictionary>

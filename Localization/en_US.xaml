<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Menu -->
    <sys:String x:Key="LOC_MediaAudit_MenuSection">Media Audit</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Menu_ScanAll">Scan All Game Media</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Menu_ScanSelected">Scan Selected Games' Media</sys:String>

    <!-- Notifications -->
    <sys:String x:Key="LOC_MediaAudit_Notification_NoSelection">Media Audit: No games selected.</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Notification_NoIssues">Media Audit: No issues found.</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Notification_IssuesFound">Media Audit: {0} issues found ({1}).</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Notification_IssuesFoundDetail">Media Audit: {0} issues found ({1}). Check game tags for details.</sys:String>

    <!-- Settings: Section Headers -->
    <sys:String x:Key="LOC_MediaAudit_Section_General">General</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_MediaTypes">Media Types to Check</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_IconStandards">Icon Standards</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_CoverStandards">Cover Standards</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_BackgroundStandards">Background Standards</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_Logo">Extra Metadata - Logo</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_Videos">Extra Metadata - Videos</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Section_GameMusic">PlayniteSound - Game Music</sys:String>

    <!-- Settings: General -->
    <sys:String x:Key="LOC_MediaAudit_Settings_BackgroundScanEnabled">Enable interval-based background scanning</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_ScanInterval">Scan interval (minutes):</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_ReportMissing">Report missing media</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_ShowScanNotification">Show notification after background scan</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_TagUndesiredMedia">Tag games with issues</sys:String>

    <!-- Settings: Media Types -->
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckIcons">Check icons</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckCovers">Check covers</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckBackgrounds">Check backgrounds</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckLogos">Check logos</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckTrailers">Check trailers</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckMicrotrailers">Check microtrailers</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_CheckGameMusic">Check game music</sys:String>

    <!-- Settings: Common Labels -->
    <sys:String x:Key="LOC_MediaAudit_Settings_Preset">Preset:</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_TagName">Tag name:</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_MinSize">Min size (px):</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_MaxSize">Max size (px):</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_AspectRatioTolerance">Aspect ratio tolerance:</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_ExpectedAspectRatio">Expected aspect ratio:</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_MinWidth">Min width (px):</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_MinHeight">Min height (px):</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_InstalledOnly">Installed games only</sys:String>

    <!-- Settings: Video-specific Labels -->
    <sys:String x:Key="LOC_MediaAudit_Settings_TrailerInstalledOnly">Trailers: installed games only</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_TrailerTagName">Trailer tag name:</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_MicrotrailerInstalledOnly">Microtrailers: installed games only</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Settings_MicrotrailerTagName">Microtrailer tag name:</sys:String>

    <!-- Validation Errors -->
    <sys:String x:Key="LOC_MediaAudit_Validation_ScanInterval">Scan interval must be at least 1 minute.</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Validation_IconMinSize">Icon minimum size must be at least 1 pixel.</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Validation_CoverMinDimensions">Cover minimum dimensions must be at least 1 pixel.</sys:String>
    <sys:String x:Key="LOC_MediaAudit_Validation_BackgroundMinDimensions">Background minimum dimensions must be at least 1 pixel.</sys:String>
</ResourceDictionary>
